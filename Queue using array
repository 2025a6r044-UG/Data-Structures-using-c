int isFull(){
    return rear == MAX-1;
} 

int isEmpty(){
   return front == -1;
} 

void enqueue(int data){
    if(isFull()){
        printf("\nQueue overflow!!\n");
        return;
    } 
    queue[++rear]=data;
    if(front==-1){
        front=rear;
    }
    printf("\n%d inserted in the queue!!!\n",data);
} 

int dequeue(){
    if(isEmpty())
        printf("Queue underflow!!\n");
        return -1; 
    int val=queue[front++];
    if(front>rear)
