#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int max;
int stack[100];
int top = -1;
 
void push(int data){
        stack[++top]=data;
}
int main() {
    scanf("%d",&max);
    int data;
    for(int i=0;i<max;i++){
        scanf("%d",&data);
        push(data);
    }
    for(int i=0;i<max;i++){
        for(int j=0;j<max-i;j++){
            if(stack[j]<stack[j+1]){
                int temp=stack[j];
                stack[j]=stack[j+1];
                stack[j+1]=temp;
            }
        }
    }
    for(int i=0;i<max;i++){
        printf("%d ",stack[i]);
    }
    return 0;
}
