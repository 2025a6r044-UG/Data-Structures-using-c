#include<stdio.h>
##include<stdlib.h>
int main() {
    int n;
    scanf("%d",&n);
    int arr[100];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    int val,ind,time;
    scanf("%d",&time);
    while(time!=0){
        scanf("%d %d",&val,&ind);
        for(int i=n-1;i>=ind;i--){
            arr[i+1]=arr[i];
        }
        time--;
        n++;
        arr[ind]=val;
    }
    for(int i=0;i<n;i++){
        printf("%d ",arr[i]);
    }
    return 0;
}
